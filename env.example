# --- Bittensor / Wallet ---
BITTENSOR_WALLET_PATH=~/.bittensor/wallets/<your-wallet>/hotkeys/<your-hotkey>
BITTENSOR_WALLET_COLD=<your-wallet>
BITTENSOR_WALLET_HOT=<your-hotkey>
BABELBIT_NETUID=59
BITTENSOR_NETWORK=finney
BITTENSOR_SUBTENSOR_ENDPOINT=finney
BITTENSOR_SUBTENSOR_FALLBACK=wss://lite.sub.latent.to:443

# --- Validator Services ---
SIGNER_URL=http://127.0.0.1:8080
# Reserved in settings; the current signer implementation uses the wallet hotkey on disk.
SIGNER_SEED=
SIGNER_HOST=127.0.0.1
SIGNER_PORT=8080
SIGNER_RETRIES=20
SIGNER_RETRY_DELAY=2

SUBTENSOR_GATEWAY_URL=http://127.0.0.1:8090
SUBTENSOR_GATEWAY_HOST=0.0.0.0
SUBTENSOR_GATEWAY_PORT=8090
SUBTENSOR_GATEWAY_TIMEOUT_S=30

# --- BabelBit APIs ---
BB_UTTERANCE_ENGINE_URL=https://api.babelbit.ai/
BB_SUBMIT_API_URL=https://scoring.babelbit.ai/
BB_SUBMIT_TIMEOUT_S=30
BB_ENABLE_VALIDATION_SUBMISSIONS=1

# --- Database ---
PG_HOST=db
PG_PORT=5432
PG_DB=babelbit
PG_USER=babelbit
PG_PASSWORD=babelbit

# --- Optional S3 / Object Storage ---
BB_ENABLE_S3_UPLOADS=0
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_SUBMISSIONS_DIR=challenges
S3_LOG_DIR=logs
S3_ADDRESSING_STYLE=path
S3_SIGNATURE_VERSION=s3v4
S3_USE_SSL=true

# --- Validator / Runner Behaviour ---
# Validator cadence is fixed to 100 blocks in the current code.
BABELBIT_TEMPO=100
BABELBIT_RUNNER_TEMPO=2160
BABELBIT_MAX_SUBTENSOR_RETRIES=5
BABELBIT_TAIL=28800
BABELBIT_ALPHA=0.2
BABELBIT_M_MIN=25
BB_RUNNER_ON_STARTUP=0
BB_ENABLE_ARENA_CHALLENGE=1
BB_ARENA_CADENCE_BLOCKS=300
BB_ARENA_RUN_ON_STARTUP=0
BB_ARENA_GATEWAY_URL=https://gw.babelbit.ai/
BB_ARENA_CONTAINERS_API_PATH=/list_arena_miners
BB_ARENA_CONTAINERS_STATUS=running
BB_ARENA_CONTAINERS_WINDOW_SECONDS=86000
BB_ARENA_CONTAINERS_TIMEOUT_SEC=10
BB_ARENA_RUNSYNC_API_PATH=/runsync
BB_ARENA_GATEWAY_AUTH_API_PATH=/auth/token
BB_ARENA_MINER_TIMEOUT_SEC=10
BB_ARENA_STARTUP_TIMEOUT_SEC=300
BB_ARENA_STARTUP_REQUEST_TIMEOUT_SEC=60
BB_ARENA_INCENTIVE_PERCENT=90
BB_MAX_SKIPPED_WEIGHT_EPOCHS=12
BB_DEFAULT_FALLBACK_UID=248
BB_SET_WEIGHTS_RETRIES=20
BB_SET_WEIGHTS_RETRY_DELAY=2
BB_ENABLE_SOLO_CHALLENGE=1
BB_MAX_MINERS_PER_RUN=256
BB_STEP_BLOCK_MODULO=0
BB_TRACE_MINER_CALLS=1

# --- Runtime Paths / Metrics / IO ---
BABELBIT_CACHE_DIR=~/.babelbit
BABELBIT_VERSION=0.1.0
BABELBIT_API_TIMEOUT_S=10
BABELBIT_MAX_CONCURRENT_API_CALLS=1
BABELBIT_METRICS_ADDR=0.0.0.0
BABELBIT_METRICS_PORT=8010
BB_CHALLENGE_STATUS_DIR=data/challenge_status
BB_OUTPUT_LOGS_DIR=logs
BB_OUTPUT_SCORES_DIR=scores

# --- Validator -> Miner Compatibility ---
BB_MINER_PREDICT_ENDPOINT=v1/predict
BB_MINER_TIMEOUT_SEC=10
BB_DEV_MODE=0
BB_LOCAL_MINER_IP=
BB_AUDIO_SCORING_METADATA_ROOT=~/.babelbit/audio_scoring/metadata
BB_AUDIO_SCORING_STT_MODEL=faster-whisper-small
BB_AUDIO_SCORING_STT_DEVICE=cpu
BB_AUDIO_SCORING_EMBEDDER=sentence-transformers/all-MiniLM-L6-v2
BB_AUDIO_SCORING_STT_CACHE_PATH=~/.babelbit/audio_scoring/stt_cache.jsonl

# --- Hugging Face / Scoring / Miner Metadata ---
HUGGINGFACE_USERNAME=
HUGGINGFACE_API_KEY=
HUGGINGFACE_CONCURRENCY=2
MINER_MODEL_ID=babelbit-ai/base-miner
MINER_MODEL_REVISION=
MINER_AXON_PORT=8092
MINER_DEVICE=cpu
MINER_LOAD_IN_8BIT=0
MINER_LOAD_IN_4BIT=0
MINER_EXTERNAL_IP=
BB_SCORER_DEVICE=cpu
BB_SCORE_PARALLELISM=4
BB_SCORE_IO_PARALLELISM=4
BB_SCORE_TORCH_THREADS=0
